<button data-confetti-button>Celebrate!</button>

<script>
  // Import from npm package.
  import confetti from 'canvas-confetti';

  // Find our component DOM on the page.
  const buttons = document.querySelectorAll('[data-confetti-button]');

  // Add event listeners to fire confetti when a button is clicked.
  // need children to be buttons
  const buttonChildren = Array.from(buttons).flatMap(button => Array.from(button.children));
  buttonChildren.forEach((child) => {
    child.addEventListener('click', () => confetti());
  });
</script>

<style>
  [data-confetti-button] {
    background-color: var(--accent-background);
    color: var(--accent-text);
    border: none;
    padding: 0.75rem 1.5rem;
    font-size: 1rem;
    border-radius: 0.5rem;
    cursor: pointer;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  [data-confetti-button]:hover {
    background-color: var(--accent-background-hover);
    color: var(--accent-text-hover);
  }

  [data-confetti-button]:focus {
    outline: 2px solid var(--accent-text);
    outline-offset: 2px;
  }
</style>